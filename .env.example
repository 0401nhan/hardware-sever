HOST=0.0.0.0
PORT=7000
PUBLIC_URL=https://server.electricbird.vn
STORE_DRIVER=mongodb
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/
# If Windows/server DNS refuses mongodb+srv SRV lookups, use a standard seed-list URI instead:
# MONGODB_URI=mongodb://USER:PASSWORD@HOST1:27017,HOST2:27017,HOST3:27017/hardware_gateway?tls=true&replicaSet=REPLICA_SET&authSource=admin&retryWrites=true&w=majority
MONGODB_DB=hardware_gateway
DB_PATH=data/hardware-server.sqlite
DEVICE_TEMPLATES_PATH=config/device-templates.yml
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
SESSION_SECRET=change-me-session-secret
TOKEN_HASH_SECRET=change-me-token-secret
PROVISIONING_TOKEN=change-me-provisioning-token
AUTO_REGISTER_GATEWAYS=true
TELEMETRY_RETENTION_MS=2592000000
TELEMETRY_PRUNE_INTERVAL_MS=3600000
